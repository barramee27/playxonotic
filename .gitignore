# Dependencies
node_modules/

# --- PlayXonotic build / install outputs (regenerate locally) ---
playxonotic/frontend/dist/
playxonotic/desktop/out/
playxonotic/desktop/node_modules/

# --- Xonotic WASM / Emscripten build outputs (regenerate with build-wasm.sh) ---
xonotic-web-port/emscripten_cache/
xonotic-web-port/emscripten_config
xonotic-web-port/source/darkplaces/build-obj/
xonotic-web-port/source/darkplaces/*.html
xonotic-web-port/source/darkplaces/*.js
xonotic-web-port/source/darkplaces/*.wasm
xonotic-web-port/source/darkplaces/*.data
build_log*.txt

# Environment and secrets — NEVER commit these
.env
.env.*
!.env.example
!**/.env.example
*.env
*.env.local
*.env.production
*.env.development
.env.*.local
backend.env.*
deploy/*.env*
**/secrets.*
*.secret

# Logs and editor junk
*.log
*.har
.DS_Store
.idea/
.vscode/
t.txt

# Large binary bundles (not source)
*.pk3
*.deb
